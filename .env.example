# LLM endpoint — Qwen2.5-7B via vLLM on Modal (or any OpenAI-compatible API)
VLLM_API_KEY=your-api-key
VLLM_BASE_URL=https://<workspace>--repomind-vllm-serve.modal.run/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Embedding endpoint — BAAI/bge-small-en-v1.5 on Modal (same VLLM_API_KEY)
EMBED_BASE_URL=https://<workspace>--repomind-vllm-embedding-api.modal.run/v1
EMBED_MODEL=BAAI/bge-small-en-v1.5

# GitHub personal access token with repo read access
GITHUB_TOKEN=ghp_your_token_here

# Inngest monitoring (dev mode — no account needed)
REPOMIND_SERVER_URL=http://localhost:8000
INNGEST_DEV_EVENT_URL=http://localhost:8288/e/repomind-dev

# Optional: LLM cost tracking (USD per 1M tokens). Defaults to 0 for local models.
# LLM_INPUT_PRICE_PER_M=0.0
# LLM_OUTPUT_PRICE_PER_M=0.0
